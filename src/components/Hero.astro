---
/*
  Hand-authored jagged equity curve, 24 points, general uptrend with two
  visible drawdown dips (around points 9-11 and 18-21). Logical space 0-1000
  (x) by 0-300 (y, 0 = top/high equity, 300 = baseline) -- this is the seed
  motion.js's initHeroViz() draws on a <canvas> and keeps extending forward
  (see src/scripts/motion.js). Values are simulated/illustrative, never a
  real track record (see the always-visible "simulated - illustrative" tag).
*/
const equityPoints: [number, number][] = [
  [0, 254.4],
  [43.5, 238.4],
  [87, 219.2],
  [130.4, 228.8],
  [173.9, 203.2],
  [217.4, 180.8],
  [260.9, 193.6],
  [304.3, 168],
  [347.8, 142.4],
  [391.3, 155.2],
  [434.8, 174.4],
  [478.3, 200],
  [521.7, 184],
  [565.2, 158.4],
  [608.7, 132.8],
  [652.2, 110.4],
  [695.7, 123.2],
  [739.1, 97.6],
  [782.6, 72],
  [826.1, 88],
  [869.6, 113.6],
  [913, 139.2],
  [956.5, 100.8],
  [1000, 49.6],
];
---

<section id="hero" aria-labelledby="hero-heading" class="relative min-h-[100svh] overflow-hidden border-b border-line">
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 opacity-50 md:h-2/3 md:opacity-100"
    data-hero-curve
    data-curve-points={JSON.stringify(equityPoints)}
    aria-hidden="true"
  >
    <!-- Live-drawing equity curve: motion.js's initHeroViz() owns this
         canvas entirely (sizing, drawing, the rAF loop). Reduced-motion
         still gets exactly one static frame drawn (seed curve + a few
         markers) -- never a blank canvas -- see initHeroViz. -->
    <canvas data-hero-canvas class="block h-full w-full"></canvas>

    <!-- Honesty tag: always visible, sits in the empty padding strip below
         the CTA row (content grid has pb-16/24, the buttons don't reach the
         very bottom edge), so it never overlaps headline/body/CTAs. -->
    <div
      data-hero-viz-label
      class="pointer-events-none absolute bottom-3 right-4 font-mono text-[10px] uppercase tracking-[0.1em] text-muted md:bottom-4 md:right-6"
    >
      simulated &middot; illustrative
    </div>

    <!-- Trading-terminal crosshair: pre-created hidden, positioned/shown by
         motion.js's initHeroCrosshair (desktop pointer:fine only, rAF-
         throttled). Absent entirely on touch/reduced-motion via the CSS
         below, in addition to the JS-side pointer:fine guard. -->
    <div data-crosshair-v aria-hidden="true"></div>
    <div data-crosshair-h aria-hidden="true"></div>
    <div data-crosshair-chip aria-hidden="true">
      <span class="text-muted" style="text-transform:uppercase; letter-spacing:0.1em;">equity</span>
      <span data-crosshair-value>0.0%</span>
    </div>
  </div>

  <!--
    The crosshair listens on the hero <section> itself (motion.js) and maps
    viewport coords onto the curve SVG's rect, so this content grid needs no
    pointer-events tricks — text stays selectable, CTAs stay ordinary links.
  -->
  <div
    class="relative z-10 mx-auto grid min-h-[100svh] max-w-6xl grid-cols-1 items-end gap-10 px-6 pb-16 pt-32 md:grid-cols-12 md:gap-6 md:px-10 md:pb-24"
  >
    <div class="md:col-span-7">
      <p data-hero-kicker class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-muted">
        <span class="text-accent">// </span>CHETRA — PHNOM PENH · SYSTEMATIC DAY TRADER
      </p>
      <h1
        id="hero-heading"
        data-hero-heading
        class="font-display font-black text-fg"
        style="font-size:clamp(3.5rem,9vw,7.5rem); line-height:0.95; letter-spacing:-0.02em;"
      >
        Discipline,<br />
        <span class="italic font-semibold text-accent">engineered.</span>
      </h1>
    </div>

    <div data-hero-copy class="flex flex-col gap-8 md:col-span-5">
      <p class="max-w-md text-lg text-muted">
        I build the machines that keep me disciplined. An autonomous strategy factory — thousands of trials,
        anti-overfit gates, locked holdout data — and a risk ladder that never negotiates.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="#factory"
          class="magnetic inline-flex items-center justify-center bg-accent px-8 py-4 font-mono text-xs uppercase tracking-[0.15em] text-bg"
        >
          View track record
        </a>
        <a
          href="#contact"
          class="magnetic inline-flex items-center justify-center border border-line px-8 py-4 font-mono text-xs uppercase tracking-[0.15em] text-fg transition-colors hover:border-accent"
        >
          Contact
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Pre-created hidden; motion.js's initHeroCrosshair only ever toggles
    opacity/transform on these (never display), matching the "elements
    pre-created hidden, transforms/opacity only" spec requirement.
    display:none under coarse pointers / no-hover / reduced-motion is a
    belt-and-suspenders match for the JS-side pointer:fine guard -- the
    feature is fully absent on touch and under reduced motion, not just
    inert.
  */
  [data-crosshair-v],
  [data-crosshair-h],
  [data-crosshair-chip] {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    pointer-events: none;
    will-change: transform;
  }

  [data-crosshair-v] {
    width: 1px;
    height: 100%;
    background: var(--color-accent);
  }

  [data-crosshair-h] {
    width: 100%;
    height: 1px;
    background: var(--color-accent);
  }

  [data-crosshair-chip] {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
    border: 1px solid var(--color-line);
    background: var(--color-elevated);
    padding: 0.2rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-fg);
  }

  @media (hover: none), (pointer: coarse) {
    [data-crosshair-v],
    [data-crosshair-h],
    [data-crosshair-chip] {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-crosshair-v],
    [data-crosshair-h],
    [data-crosshair-chip] {
      display: none;
    }
  }
</style>
