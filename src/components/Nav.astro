---
const links = [
  { label: 'Work', href: '/work/' },
  { label: 'Track record', href: '/#factory' },
  { label: 'Systems', href: '/#systems' },
  { label: 'Contact', href: '/#contact' },
  { label: 'Notes', href: '/notes/' },
  { label: 'Tearsheet', href: '/tearsheet/' },
];

// Current section from the request path: /work* -> Work, /notes* -> Notes.
// Contact is an in-page anchor, never "active". This gets the FIRST paint
// (hard load, and the non-persisted #nav-overlay on every soft nav) right;
// the persisted <header> additionally needs motion.js's astro:page-load
// sync because its DOM node survives client-side navs untouched -- see
// syncNavActiveState() there.
const pathname = Astro.url.pathname;
function isActiveLink(href: string) {
  if (href.startsWith('/#')) return false;
  return pathname === href || pathname.startsWith(href);
}
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line bg-bg/90 backdrop-blur"
  transition:persist
  transition:name="site-nav"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 md:px-10" aria-label="Primary">
    <a href="/" class="font-mono text-sm text-fg">
      chetra.xyz<span class="text-accent">.</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      <ul class="flex items-center gap-1 font-mono text-xs uppercase tracking-[0.15em]">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav-link
                aria-current={isActiveLink(link.href) ? 'page' : undefined}
                class:list={[
                  'block px-3 py-2 underline underline-offset-4 transition-colors hover:text-accent hover:decoration-accent',
                  isActiveLink(link.href) ? 'text-accent decoration-accent' : 'text-fg decoration-transparent',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <button
        type="button"
        data-palette-open
        class="font-mono text-[11px] uppercase tracking-[0.1em] text-muted transition-colors hover:text-accent"
        aria-label="Open command palette"
      >
        ⌘K
      </button>
      <button
        type="button"
        data-theme-toggle
        class="flex h-7 w-7 shrink-0 items-center justify-center border border-line text-fg transition-colors hover:border-accent"
        aria-label="Switch to dark theme"
        aria-pressed="true"
      >
        <svg data-icon-sun width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg data-icon-moon width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z" />
        </svg>
      </button>
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="nav-toggle relative z-50 h-8 w-8 md:hidden"
      aria-expanded="false"
      aria-controls="nav-overlay"
      aria-label="Open menu"
    >
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
    </button>
  </nav>
</header>

{/* Outside <header>: its backdrop-blur creates a containing block that would
    trap this fixed overlay at the header's 64px height. */}
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center bg-bg md:hidden"
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <ul class="flex flex-col items-center gap-10 font-display text-[2.5rem]">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            data-nav-link
            aria-current={isActiveLink(link.href) ? 'page' : undefined}
            class:list={[
              'nav-overlay-link underline underline-offset-4 transition-colors hover:text-accent hover:decoration-accent',
              isActiveLink(link.href) ? 'text-accent decoration-accent' : 'text-fg decoration-transparent',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
  <button
    type="button"
    data-theme-toggle
    class="mt-10 flex h-11 w-11 shrink-0 items-center justify-center border border-line text-fg transition-colors hover:border-accent"
    aria-label="Switch to dark theme"
    aria-pressed="true"
  >
    <svg data-icon-sun width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
    <svg data-icon-moon width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z" />
    </svg>
  </button>
</div>

<style>
  .hamburger-line {
    position: absolute;
    left: 50%;
    top: 12px;
    width: 20px;
    height: 2px;
    background: var(--color-fg);
    transform: translateX(-50%);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .hamburger-line:nth-child(2) {
    top: 20px;
  }

  .nav-toggle.is-open .hamburger-line {
    top: 16px;
  }

  .nav-toggle.is-open .hamburger-line:nth-child(1) {
    transform: translateX(-50%) rotate(45deg);
  }

  .nav-toggle.is-open .hamburger-line:nth-child(2) {
    transform: translateX(-50%) rotate(-45deg);
  }

  .nav-overlay-link {
    display: inline-block;
  }
</style>
