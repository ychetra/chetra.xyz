---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const totalCount = allProjects.length;

const featured = allProjects
  .filter((p) => p.data.tier === 'featured')
  .sort((a, b) => a.data.order - b.data.order || b.data.year.localeCompare(a.data.year))
  .slice(0, 4);
---

<section id="projects" aria-labelledby="projects-heading" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    <h2 id="projects-heading" class="sr-only">Projects</h2>
    <p class="mb-10 font-mono text-xs uppercase tracking-[0.25em] text-muted"><span class="text-accent">// </span>PROJECTS</p>

    <div class="grid grid-cols-1 gap-px bg-line sm:grid-cols-2" data-reveal-group>
      {
        featured.map((project, i) => {
          const slug = project.data.slug ?? project.id;
          return (
            <a
              href={`/work/${slug}`}
              class="project-card group flex flex-col justify-between bg-bg p-8 transition-colors duration-300 hover:bg-surface"
              data-reveal-item
            >
              <div>
                <span class="mb-6 block font-mono text-sm text-accent transition-transform duration-300 group-hover:translate-x-1">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="mb-3 font-display text-2xl text-fg transition-colors duration-300 group-hover:text-accent">
                  {project.data.title}
                </h3>
                <p class="text-[0.95rem] text-muted">{project.data.tagline}</p>
              </div>
              <p class="mt-8 font-mono text-[11px] uppercase tracking-[0.15em] text-muted">
                {project.data.stack.join(' · ')}
              </p>
            </a>
          );
        })
      }
    </div>

    <p class="mt-10 text-right">
      <a
        href="/work"
        class="font-mono text-xs uppercase tracking-[0.15em] text-muted underline decoration-transparent underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
      >
        View all {totalCount} projects → /work
      </a>
    </p>
  </div>
</section>
