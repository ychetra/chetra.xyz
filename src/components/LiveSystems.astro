---
/*
  Live systems — bridge from the portfolio to real running deployments.
  One flagship card for now (trading.chetra.xyz, behind auth). The status
  dot is a real client-side reachability check (no-cors fetch from the
  visitor's browser, see motion.js initSystemStatus) — never a hardcoded
  "online" badge. The preview is a styled frame, not a fake screenshot:
  the instance is auth-walled and we don't pretend otherwise.
*/
const system = {
  name: 'Trading Cockpit',
  domain: 'trading.chetra.xyz',
  url: 'https://trading.chetra.xyz',
  description:
    'The live command view of the strategy factory — equity, open risk, pipeline state. Runs against the real pipeline, behind auth.',
  stack: 'FASTAPI · MONGODB · ECHARTS',
};
---

<section id="systems" aria-labelledby="systems-heading" class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    <h2 id="systems-heading" class="sr-only">Live systems</h2>
    <p class="mb-10 font-mono text-xs uppercase tracking-[0.25em] text-muted">
      <span class="text-accent">// </span>LIVE SYSTEMS
    </p>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-16" data-reveal-group>
      <!-- Styled auth frame: a terminal surface, deliberately dark in both themes -->
      <a
        href={system.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group block"
        data-reveal-item
        aria-label={`${system.name} — live instance, opens in new tab`}
      >
        <figure
          data-theme-lock="dark"
          class="relative overflow-hidden border border-line bg-elevated transition-colors duration-300 group-hover:border-accent"
        >
          <img
            src="/systems/trading-cockpit.jpg"
            alt="The trading cockpit's System view — MT5 bridge and MongoDB health, 19-agent monitor, and a live spread-drift table across 15 instruments."
            width="1600"
            height="688"
            loading="lazy"
            decoding="async"
            class="block w-full"
          />
          <figcaption
            class="flex items-center justify-between gap-3 border-t border-line px-3 py-2 font-mono text-[10px] uppercase tracking-[0.1em] text-muted"
          >
            <span class="inline-flex items-center gap-1.5">
              <svg
                class="h-3 w-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <rect x="4" y="11" width="16" height="9" />
                <path d="M8 11V7a4 4 0 0 1 8 0v4" />
              </svg>
              Behind auth — live instance
            </span>
            <span class="opacity-60">real screenshot · 2026-07-04</span>
          </figcaption>
        </figure>
      </a>

      <div class="flex flex-col justify-center" data-reveal-item>
        <div class="mb-4 flex items-center gap-3 font-mono text-xs uppercase tracking-[0.15em]">
          <span class="inline-flex items-center gap-2" data-system-status data-system-url={system.url}>
            <span
              class="h-2 w-2 bg-muted"
              data-system-status-dot
              aria-hidden="true"
            ></span>
            <span class="text-muted" data-system-status-label>CHECKING…</span>
          </span>
          <span class="text-muted opacity-60">checked from your browser</span>
        </div>
        <h3 class="mb-3 font-display text-2xl text-fg">{system.name}</h3>
        <p class="mb-6 max-w-md text-muted">{system.description}</p>
        <p class="mb-8 font-mono text-[11px] uppercase tracking-[0.15em] text-muted">{system.stack}</p>
        <div class="flex flex-wrap items-center gap-6">
          <a
            href={system.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs uppercase tracking-[0.15em] text-accent underline underline-offset-4"
          >
            {system.domain} ↗<span class="sr-only"> (opens in new tab)</span>
          </a>
          <a
            href="/work/trading-cockpit/"
            class="font-mono text-xs uppercase tracking-[0.15em] text-muted underline underline-offset-4 hover:text-accent"
          >
            About this system
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
